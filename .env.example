# ==========================================
# ENV TEMPLATE UNTUK DEPLOYMENT (VERCEL/DLL)
# ==========================================
# Ganti nilai di bawah ini dengan kredensial Supabase produksi Anda.
# Jangan pernah melakukan commit file .env sungguhan ke repositori Git!

# 1. URL Project Supabase Anda
# Contoh: https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_ID].supabase.co"

# 2. Key Anon/Public Supabase Anda 
# (Biasanya berawalan "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...")
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-publishable-key-here"

# (Jika Dibutuhkan) URL Utama Aplikasi Anda saat produksi 
# Gunakan ini untuk pengaturan Redirect Auth (Email Verification/OAuth)
# NEXT_PUBLIC_SITE_URL="https://domain-anda.com"
